---
import data from '../data/findings.json';
const m = data.meta;
---
<footer class="footer dark">
  <div class="container foot-grid">
    <div class="foot-brand">
      <div class="brand"><span class="brand-mark"></span> skew<span class="brand-dim">-dynamic</span></div>
      <p class="muted">An open research study by Cold Code Labs on the structural invariance of return skewness in football betting markets.</p>
      <p class="mono ds">dataset · {m.n_matches.toLocaleString('en')} matches · {m.leagues} leagues · sha256 {m.sha256}…</p>
    </div>
    <div class="foot-col">
      <h4>Study</h4>
      <a href="/paper">The paper</a>
      <a href="https://github.com/cold-code-labs/skew-dynamic/blob/main/study/docs/FINDINGS.md" target="_blank" rel="noopener">Findings log</a>
      <a href="https://github.com/cold-code-labs/skew-dynamic/blob/main/study/docs/METHODOLOGY.md" target="_blank" rel="noopener">Methodology</a>
      <a href="https://github.com/cold-code-labs/skew-dynamic/blob/main/study/docs/LITERATURA.md" target="_blank" rel="noopener">Literature</a>
    </div>
    <div class="foot-col">
      <h4>Open</h4>
      <a href="https://github.com/cold-code-labs/skew-dynamic" target="_blank" rel="noopener">Code & data ↗</a>
      <a href="https://github.com/cold-code-labs/skew-dynamic#reproduce" target="_blank" rel="noopener">Reproduce</a>
      <a href="https://github.com/cold-code-labs/skew-dynamic/blob/main/LICENSE" target="_blank" rel="noopener">Apache-2.0 · CC-BY-4.0</a>
      <a href="https://coldcodelabs.com" target="_blank" rel="noopener">Cold Code Labs ↗</a>
    </div>
  </div>
  <div class="container foot-bottom">
    <span>© 2026 Cold Code Labs</span>
    <span class="muted">Code Apache-2.0 · paper CC-BY-4.0 · data © football-data.co.uk</span>
  </div>
</footer>
<style>
  .footer { padding: 72px 0 36px; }
  .foot-grid { display: grid; gap: 32px; }
  @media (min-width: 760px) { .foot-grid { grid-template-columns: 2fr 1fr 1fr; gap: 48px; } }
  .footer .brand { color: #fff; font-weight: 650; display: flex; align-items: center; gap: 9px; font-size: 1.1rem; }
  .footer .brand-dim { color: #6f87a4; font-weight: 500; }
  .footer .brand-mark { width: 16px; height: 16px; border-radius: 5px; background: linear-gradient(135deg, var(--accent), var(--ice)); }
  .foot-brand p { margin: 14px 0 0; max-width: 42ch; }
  .ds { font-size: .76rem; color: #6f87a4; }
  .foot-col h4 { color: #cfe0f2; font-size: .76rem; letter-spacing: .12em; text-transform: uppercase; font-family: var(--mono); font-weight: 500; margin: 0 0 14px; }
  .foot-col a { display: block; color: #9fb6cf; font-size: .94rem; padding: 4px 0; }
  .foot-col a:hover { color: #fff; text-decoration: none; }
  .foot-bottom { display: flex; flex-wrap: wrap; gap: 8px 24px; justify-content: space-between; margin-top: 48px; padding-top: 24px; border-top: 1px solid #1d3a5f; font-size: .82rem; color: #8fa8c4; }
</style>
