---
// SkewMeter — instrumento interativo de SIMILARIDADE DE ASSIMETRIAS (Fase Q).
// Mede a assinatura de assimetria de uma liga (gauge + banda de incerteza), mostra
// o resíduo contra a lei, e responde "esta liga é como X, diferente de Y".
// Sem backend: lê findings.json + JS no cliente. Idioma de LawChart/FlbChart.
import data from '../data/findings.json';
// junta o exkurt por liga (moments.leagues) p/ a distância de FORMA de Mahalanobis
const EK = Object.fromEntries(data.moments.leagues.map(d=>[d.code,d.exkurt]));
const L = [...data.leagues].sort((a,b)=>a.skew-b.skew).map(d=>({...d, exkurt: EK[d.code]}));
const SM = data.skewmeter, CV = data.convergence, curve = SM.curve;
const CINV = SM.shape_cov_inv;        // métrica de Mahalanobis auditada (bloco 45)
const def = L.find(d=>d.code==='E0') ? 'E0' : L[Math.floor(L.length/2)].code;
// tetos de explicação: com odds (lei, p_fav) vs sem odds (upset do Elo)
const corrOdds = SM.r2_1param, corrFree = SM.corr_oddsfree;

// Painel A — gauge horizontal (skew −0.05 … 0.40)
const GW=720, GH=120, glo=-0.05, ghi=0.40, gpad=46;
const gx = (s)=> gpad + ((s-glo)/(ghi-glo))*(GW-2*gpad);
const gticks=[0.0,0.1,0.2,0.3];

// Painel B — lei (reusa a geometria do LawChart)
const W=680,H=360,P={l:54,r:18,t:18,b:42}, xlo=0.43,xhi=0.60,ylo=0.06,yhi=0.34;
const X=(p)=>P.l+((p-xlo)/(xhi-xlo))*(W-P.l-P.r);
const Y=(s)=>P.t+(1-(s-ylo)/(yhi-ylo))*(H-P.t-P.b);
const cpts = curve.filter(d=>d.p_fav>=xlo&&d.p_fav<=xhi).map(d=>`${X(d.p_fav).toFixed(1)},${Y(d.skew).toFixed(1)}`);

// Painel D — tipo de aposta (bloco 46): três séries skew vs competitividade
const BT = data.bettype, btL = BT.leagues;
const BW=680,BH=300,BP={l:46,r:14,t:16,b:40};
const bxlo=Math.min(...btL.map(d=>d.p_fav))-0.006, bxhi=Math.max(...btL.map(d=>d.p_fav))+0.006;
const bymax=Math.ceil(Math.max(...btL.map(d=>d.dog))*10)/10;
const BX=(p)=>BP.l+((p-bxlo)/(bxhi-bxlo))*(BW-BP.l-BP.r);
const BY=(s)=>BP.t+(1-(s/bymax))*(BH-BP.t-BP.b);
const BETS=[['dog','underdog','#d05a4f'],['draw','draw','#9a8c5a'],['fav','favourite','#4a78b5']];

// Painel E — diversificação (bloco 37): skewness do retorno médio de N apostas
const DV = data.diversification, sizes=DV.sizes, Nmax=sizes[sizes.length-1];
const DW=680,DH=300,DP={l:46,r:14,t:16,b:40};
const dymax=Math.ceil(Math.max(DV.base_dog, ...DV.dog)*10)/10;
const lx=(N)=>DP.l+(Math.log(N)/Math.log(Nmax))*(DW-DP.l-DP.r);
const dy=(s)=>DP.t+(1-(Math.max(0,s)/dymax))*(DH-DP.t-DP.b);
const dline=(arr)=>arr.map((s,i)=>`${lx(sizes[i]).toFixed(1)},${dy(s).toFixed(1)}`).join(' ');
const dpred=(base)=>sizes.map(N=>`${lx(N).toFixed(1)},${dy(base/Math.sqrt(N)).toFixed(1)}`).join(' ');
---
<figure class="sm">
  <div class="sm-controls">
    <label>League
      <select id="sm-league">
        {L.slice().reverse().map(d=>(<option value={d.code} selected={d.code===def}>{d.name} ({d.code})</option>))}
      </select>
    </label>
    <label class="sm-k">Sample window: <b><span id="sm-kval">380</span> matches</b>
      <input id="sm-k" type="range" min="50" max="800" step="10" value="380" />
    </label>
  </div>

  <!-- PANEL A — gauge -->
  <div class="sm-panel">
    <div class="sm-readout">
      <span class="big" id="sm-skew">+0.00</span><span class="lbl">skewness</span>
      <span class="big" id="sm-pfav">0.00</span><span class="lbl">p<sub>fav</sub> · with odds</span>
      <span class="big alt" id="sm-upset">0.00</span><span class="lbl">upset · odds-free</span>
      <span class="word" id="sm-word">—</span>
    </div>
    <svg viewBox={`0 0 ${GW} ${GH}`} class="sm-gauge" role="img" aria-label="asymmetry gauge">
      <line x1={gpad} y1="64" x2={GW-gpad} y2="64" stroke="var(--line)" stroke-width="6" stroke-linecap="round"/>
      {gticks.map(t=>(<g><line x1={gx(t)} y1="56" x2={gx(t)} y2="72" stroke="var(--ink-faint)" stroke-width="1.5"/><text class="sm-tick" x={gx(t)} y="92" text-anchor="middle">{t.toFixed(1)}</text></g>))}
      <rect id="sm-band" x={gx(0)} y="58" width="0" height="12" rx="3" fill="var(--accent)" opacity=".25"/>
      <line id="sm-needle" x1={gx(0)} y1="48" x2={gx(0)} y2="80" stroke="var(--accent)" stroke-width="3.5" stroke-linecap="round"/>
      <text class="sm-tick" x={gpad} y="34" text-anchor="start">← balanced</text>
      <text class="sm-tick" x={GW-gpad} y="34" text-anchor="end">lottery-like →</text>
    </svg>
    <p class="sm-cap">The band is sampling noise — drag the window: it shrinks as the season runs, resolving the league below the between-league spread (<span class="mono">{SM.sd_between.toFixed(3)}</span>) in ~half a season. The same signature reads off prices (p<sub>fav</sub>, R²&nbsp;<span class="mono">{(corrOdds*100).toFixed(0)}%</span>) or off <b>results alone</b> (upset rate, ceiling corr&nbsp;<span class="mono">{corrFree.toFixed(2)}</span>) — dropping the odds costs almost nothing.</p>
  </div>

  <div class="sm-two">
    <!-- PANEL B — the law + residual -->
    <div class="sm-panel">
      <h4>Where it sits on the law</h4>
      <svg viewBox={`0 0 ${W} ${H}`} class="sm-law" role="img" aria-label="league on the skewness law">
        {[0.45,0.50,0.55].map(t=>(<text class="sm-tick" x={X(t)} y={H-P.b+16} text-anchor="middle">{t.toFixed(2)}</text>))}
        {[0.10,0.20,0.30].map(t=>(<g><line x1={P.l} y1={Y(t)} x2={W-P.r} y2={Y(t)} stroke="var(--line)" stroke-opacity=".4"/><text class="sm-tick" x={P.l-8} y={Y(t)+4} text-anchor="end">{t.toFixed(2)}</text></g>))}
        <polyline points={cpts.join(' ')} fill="none" stroke="var(--ink-faint)" stroke-width="2.5" opacity=".8"/>
        {L.map(d=>(<circle class="sm-dot" data-code={d.code} cx={X(d.p_fav)} cy={Y(d.skew)} r="5" fill="var(--accent)" fill-opacity=".35" stroke="#fff" stroke-width="1"
          data-tip={`${d.code}  skew=${d.skew.toFixed(3)}  residual=${d.residual.toFixed(3)}`}/>))}
        <line id="sm-drop" x1="0" y1="0" x2="0" y2="0" stroke="var(--accent)" stroke-width="1.5" stroke-dasharray="3 3"/>
        <circle id="sm-ring" cx="0" cy="0" r="8" fill="none" stroke="var(--accent)" stroke-width="2.5"/>
        <text class="sm-axis" x={W/2} y={H-4} text-anchor="middle">mean favourite probability (more predictable →)</text>
        <text class="sm-axis" x="14" y={H/2} text-anchor="middle" transform={`rotate(-90 14 ${H/2})`}>league skewness</text>
      </svg>
      <p class="sm-cap">The dashed drop-line is the <b>residual</b> — the asymmetry competitiveness does <i>not</i> explain. One parameter explains <span class="mono">{(SM.r2_1param*100).toFixed(0)}%</span> of the cross-league variance.</p>
    </div>

    <!-- PANEL C — similarity -->
    <div class="sm-panel">
      <h4>Like <span id="sm-name">—</span>, unlike…</h4>
      <div class="sm-sim sm-sim3">
        <div><div class="sm-h">Raw |Δskew|</div><ol id="sm-raw" class="sm-list"></ol></div>
        <div><div class="sm-h">Shape (Mahalanobis)</div><ol id="sm-shape" class="sm-list"></ol></div>
        <div><div class="sm-h">After competitiveness</div><ol id="sm-res" class="sm-list"></ol></div>
      </div>
      <p class="sm-verdict" id="sm-verdict">—</p>
      <p class="sm-cap"><b>Similarity of asymmetries = similarity of competitiveness.</b> The middle column is the 2-D shape distance (skew + excess-kurtosis) under the audited Mahalanobis metric — it ranks neighbours like raw |Δskew| (corr 0.74). Verdict by equivalence (margin ½·sd = <span class="mono">{SM.margin.toFixed(3)}</span>), not a significance test.</p>
    </div>
  </div>

  <!-- PANEL D — bet-type: every side of the book -->
  <div class="sm-panel">
    <div class="sm-d-head">
      <h4>Every side of the book</h4>
      <div class="sm-seg" id="bt-seg" role="group" aria-label="bet type">
        <button data-bet="all" class="on">all</button>
        <button data-bet="fav">favourite</button>
        <button data-bet="draw">draw</button>
        <button data-bet="dog">underdog</button>
      </div>
    </div>
    <svg viewBox={`0 0 ${BW} ${BH}`} class="sm-law" id="bt-svg" role="img" aria-label="skewness of the three bet objects vs competitiveness">
      {[0,0.5,1.0,1.5,2.0,2.5].filter(t=>t<=bymax).map(t=>(<g><line x1={BP.l} y1={BY(t)} x2={BW-BP.r} y2={BY(t)} stroke="var(--line)" stroke-opacity=".4"/><text class="sm-tick" x={BP.l-7} y={BY(t)+4} text-anchor="end">{t.toFixed(1)}</text></g>))}
      {[0.46,0.50,0.54,0.58].filter(t=>t>=bxlo&&t<=bxhi).map(t=>(<text class="sm-tick" x={BX(t)} y={BH-BP.b+16} text-anchor="middle">{t.toFixed(2)}</text>))}
      <line id="bt-guide" x1="0" y1={BP.t} x2="0" y2={BH-BP.b} stroke="var(--accent)" stroke-width="1.2" stroke-dasharray="3 3" opacity="0"/>
      {BETS.map(([k,lab,col])=>(<g class={`bt-series bt-${k}`}>
        {btL.map(d=>(<circle class="bt-pt" data-code={d.code} cx={BX(d.p_fav)} cy={BY(d[k])} r="4" fill={col} fill-opacity=".55" stroke="#fff" stroke-width=".6"/>))}
        <text class="bt-corr" x={BW-BP.r-6} y={BP.t+14+BETS.findIndex(b=>b[0]===k)*15} text-anchor="end" fill={col}>{lab} · corr {BT.corr[k]>=0?'+':''}{BT.corr[k].toFixed(2)}</text>
      </g>))}
      <text class="sm-axis" x={BW/2} y={BH-4} text-anchor="middle">mean favourite probability (less competitive →)</text>
    </svg>
    <p class="sm-cap">Same law, mirrored across the book: as a league tilts (p<sub>fav</sub> ↑), the <b>favourite</b> bet flattens while the <b>draw</b> and <b>underdog</b> become bigger longshots. The selected league is ringed in all three.</p>
  </div>

  <!-- PANEL E — diversification -->
  <div class="sm-panel">
    <h4>What survives diversification</h4>
    <svg viewBox={`0 0 ${DW} ${DH}`} class="sm-law" role="img" aria-label="skewness of the average return of N bets">
      {[0,0.5,1.0,1.5,2.0].filter(t=>t<=dymax).map(t=>(<g><line x1={DP.l} y1={dy(t)} x2={DW-DP.r} y2={dy(t)} stroke="var(--line)" stroke-opacity=".4"/><text class="sm-tick" x={DP.l-7} y={dy(t)+4} text-anchor="end">{t.toFixed(1)}</text></g>))}
      {[1,10,100,Nmax].map(t=>(<text class="sm-tick" x={lx(t)} y={DH-DP.b+16} text-anchor="middle">{t}</text>))}
      <line x1={DP.l} y1={dy(0.1)} x2={DW-DP.r} y2={dy(0.1)} stroke="var(--ink-faint)" stroke-width="1" stroke-dasharray="2 3"/>
      <text class="sm-tick" x={DP.l+4} y={dy(0.1)-4} text-anchor="start">≈ gaussian (0.1)</text>
      <polyline points={dpred(DV.base_dog)} fill="none" stroke="#d05a4f" stroke-width="1" stroke-dasharray="4 3" opacity=".5"/>
      <polyline points={dpred(DV.base_fav)} fill="none" stroke="#4a78b5" stroke-width="1" stroke-dasharray="4 3" opacity=".5"/>
      <polyline points={dline(DV.dog)} fill="none" stroke="#d05a4f" stroke-width="2.4"/>
      <polyline points={dline(DV.fav)} fill="none" stroke="#4a78b5" stroke-width="2.4"/>
      <line x1={lx(DV.n_gauss_fav)} y1={dy(0.1)} x2={lx(DV.n_gauss_fav)} y2={DH-DP.b} stroke="#4a78b5" stroke-width="1" opacity=".6"/>
      <line x1={lx(DV.n_gauss_dog)} y1={dy(0.1)} x2={lx(DV.n_gauss_dog)} y2={DH-DP.b} stroke="#d05a4f" stroke-width="1" opacity=".6"/>
      <text class="bt-corr" x={lx(DV.n_gauss_fav)} y={DH-BP.b+2} text-anchor="middle" fill="#4a78b5">favourite ~{DV.n_gauss_fav}</text>
      <text class="bt-corr" x={lx(DV.n_gauss_dog)} y={DH-BP.b+2} text-anchor="end" fill="#d05a4f">underdog ~{DV.n_gauss_dog}</text>
      <text class="sm-axis" x={DW/2} y={DH-4} text-anchor="middle">bets in the portfolio N (log)</text>
    </svg>
    <p class="sm-cap">Skewness is a <b>single-bet</b> phenomenon: the average return of N independent bets carries skew ≈ skew/√N. A favourite book washes out by <b>~{DV.n_gauss_fav}</b> bets; the underdog's lottery survives to <b>~{DV.n_gauss_dog}</b> — which is why the bias bites the recreational bettor, not the diversified syndicate.</p>
  </div>
</figure>

<script define:vars={{ L, SM, CV, CINV, curve, def, gpad, GW, glo, ghi, W, H, P, xlo, xhi, ylo, yhi }}>
  const $ = (id)=>document.getElementById(id);
  const gx = (s)=> gpad + ((s-glo)/(ghi-glo))*(GW-2*gpad);
  const X=(p)=>P.l+((p-xlo)/(xhi-xlo))*(W-P.l-P.r);
  const Y=(s)=>P.t+(1-(s-ylo)/(yhi-ylo))*(H-P.t-P.b);
  const byCode = Object.fromEntries(L.map(d=>[d.code,d]));
  // predict_skew(p) — interp linear sobre a curva da lei (= np.interp)
  const predict = (p)=>{ const c=curve;
    if(p<=c[0].p_fav) return c[0].skew;
    for(let i=1;i<c.length;i++) if(p<=c[i].p_fav){const a=c[i-1],b=c[i],t=(p-a.p_fav)/(b.p_fav-a.p_fav);return a.skew+t*(b.skew-a.skew);}
    return c[c.length-1].skew; };
  // SE interpolada na janela K (sobre o array de convergência)
  const seAt = (K)=>{ const k=CV.k, s=CV.se;
    if(K<=k[0]) return s[0]; if(K>=k[k.length-1]) return s[s.length-1];
    for(let i=1;i<k.length;i++) if(K<=k[i]){const t=(K-k[i-1])/(k[i]-k[i-1]);return s[i-1]+t*(s[i]-s[i-1]);}
    return s[s.length-1]; };
  const word = (d)=>{ const a=Math.abs(d.skew);
    if(a>=0.27) return 'strongly lottery-like'; if(a>=0.18) return 'tilted'; if(a>=0.10) return 'mildly tilted'; return 'near-balanced'; };

  function render(code, K){
    const d = byCode[code];
    // PANEL A
    $('sm-skew').textContent = (d.skew>=0?'+':'')+d.skew.toFixed(3);
    $('sm-pfav').textContent = d.p_fav.toFixed(2);
    $('sm-upset').textContent = (d.upset!=null?d.upset.toFixed(2):'—');
    $('sm-word').textContent = word(d);
    const se = seAt(K);
    $('sm-needle').setAttribute('x1', gx(d.skew)); $('sm-needle').setAttribute('x2', gx(d.skew));
    $('sm-band').setAttribute('x', gx(d.skew-se)); $('sm-band').setAttribute('width', Math.max(0, gx(d.skew+se)-gx(d.skew-se)));
    // PANEL B — ring + drop-line (residual)
    const cx=X(d.p_fav), cy=Y(d.skew), cyhat=Y(d.skew-d.residual);
    $('sm-ring').setAttribute('cx',cx); $('sm-ring').setAttribute('cy',cy);
    $('sm-drop').setAttribute('x1',cx); $('sm-drop').setAttribute('y1',cy);
    $('sm-drop').setAttribute('x2',cx); $('sm-drop').setAttribute('y2',cyhat);
    document.querySelectorAll('.sm-dot').forEach(el=>{ const on=el.getAttribute('data-code')===code;
      el.setAttribute('fill-opacity', on?'0.95':'0.3'); el.setAttribute('r', on?'6':'5'); });
    // PANEL C — vizinhos raw vs residual
    $('sm-name').textContent = code;
    const others = L.filter(x=>x.code!==code);
    // distância de forma de MAHALANOBIS em (skew, exkurt) — métrica auditada (CINV)
    const maha = (x)=>{ const u=x.skew-d.skew, v=x.exkurt-d.exkurt;
      return Math.sqrt(u*(CINV[0][0]*u+CINV[0][1]*v) + v*(CINV[1][0]*u+CINV[1][1]*v)); };
    const raw = [...others].sort((a,b)=>Math.abs(a.skew-d.skew)-Math.abs(b.skew-d.skew));
    const shp = [...others].sort((a,b)=>maha(a)-maha(b));
    const res = [...others].sort((a,b)=>Math.abs(a.residual-d.residual)-Math.abs(b.residual-d.residual));
    const row = (x,val,scale)=>`<li><span class="c">${x.code}</span><span class="b"><span style="width:${Math.min(100,val/scale*100)}%"></span></span><span class="v">${val.toFixed(scale<1?3:1)}</span></li>`;
    $('sm-raw').innerHTML = raw.slice(0,4).map(x=>row(x,Math.abs(x.skew-d.skew),0.22)).join('');
    $('sm-shape').innerHTML = shp.slice(0,4).map(x=>row(x,maha(x),Math.max(...others.map(maha)))).join('');
    $('sm-res').innerHTML = res.slice(0,4).map(x=>row(x,Math.abs(x.residual-d.residual),0.22)).join('');
    // PANEL D — destaca a liga nas três séries + guia vertical
    document.querySelectorAll('.bt-pt').forEach(el=>{ const on=el.getAttribute('data-code')===code;
      el.setAttribute('r', on?'6':'4'); el.setAttribute('fill-opacity', on?'1':'.5'); el.style.stroke=on?'#222':'#fff'; });
    const bg=$('bt-guide'), any=document.querySelector(`.bt-pt[data-code="${code}"]`);
    if(bg&&any){ const cx=any.getAttribute('cx'); bg.setAttribute('x1',cx); bg.setAttribute('x2',cx); bg.setAttribute('opacity','.5'); }
    // verdict: o caso pedagógico é "parece diferente, é a MESMA forma" — a liga
    // MAIS distante no skew bruto que ainda é equivalente no resíduo.
    const eq = others.filter(x=>Math.abs(x.residual-d.residual) < SM.margin)
                     .sort((a,b)=>Math.abs(b.skew-d.skew)-Math.abs(a.skew-d.skew));
    const nb = eq.length ? eq[0] : res[0];
    const rawd=Math.abs(nb.skew-d.skew), rd=Math.abs(nb.residual-d.residual), same = rd < SM.margin;
    $('sm-verdict').className = 'sm-verdict ' + (same?'ok':'no');
    $('sm-verdict').innerHTML = same
      ? `<b>${d.code} vs ${nb.code}:</b> raw skewness differs by <b>${rawd.toFixed(3)}</b>, but once competitiveness is removed the gap is just <b>${rd.toFixed(3)}</b> (within the ${SM.margin.toFixed(3)} margin) → <b>same asymmetry</b>`
      : `<b>${d.code} vs ${nb.code}:</b> closest in conditioned asymmetry (residual gap ${rd.toFixed(3)}) — still a genuine difference`;
  }
  const sel=$('sm-league'), kk=$('sm-k');
  const go=()=>{ $('sm-kval').textContent=kk.value; render(sel.value, +kk.value); };
  sel.addEventListener('change', go); kk.addEventListener('input', go);
  // segmented control do tipo de aposta: realça uma série (esmaece as outras)
  const seg=$('bt-seg'), svg=$('bt-svg');
  if(seg) seg.addEventListener('click', e=>{ const b=e.target.closest('button'); if(!b) return;
    seg.querySelectorAll('button').forEach(x=>x.classList.toggle('on', x===b));
    svg.className.baseVal = 'sm-law' + (b.dataset.bet==='all'?'':' emph-'+b.dataset.bet); });
  render(def, 380);
</script>

<style>
  .sm { margin:0; }
  .sm-controls { display:flex; gap:24px; flex-wrap:wrap; align-items:center; margin-bottom:18px; font-size:.9rem; }
  .sm-controls label { display:flex; flex-direction:column; gap:4px; color:var(--ink-soft); }
  .sm-controls select { font:inherit; padding:6px 10px; border:1px solid var(--line); border-radius:8px; background:var(--surface); color:var(--ink); min-width:240px; }
  .sm-k { flex:1; min-width:240px; }
  .sm-k input { width:100%; accent-color:var(--accent); }
  .sm-panel { background:var(--surface); border:1px solid var(--line); border-radius:12px; padding:16px 18px; margin-bottom:18px; }
  .sm-panel h4 { margin:0 0 10px; font-size:1rem; }
  .sm-readout { display:flex; align-items:baseline; gap:8px 16px; flex-wrap:wrap; margin-bottom:6px; }
  .sm-readout .big { font-family:var(--mono); font-size:1.7rem; font-weight:600; color:var(--accent); }
  .sm-readout .big.alt { color:var(--ink-soft); }
  .sm-readout .lbl { font-size:.78rem; color:var(--ink-soft); margin-right:8px; }
  .sm-readout .word { margin-left:auto; font-family:var(--mono); font-size:.85rem; color:var(--ink-soft); text-transform:uppercase; letter-spacing:.08em; }
  .sm-gauge, .sm-law { width:100%; height:auto; }
  .sm-tick { font-family:var(--mono); font-size:11px; fill:var(--ink-soft); }
  .sm-axis { font-size:12px; fill:var(--ink-soft); }
  .sm-cap { font-size:.82rem; color:var(--ink-soft); margin:8px 0 0; max-width:70ch; }
  .sm-two { display:grid; grid-template-columns:1fr 1fr; gap:18px; }
  @media (max-width:760px){ .sm-two{ grid-template-columns:1fr; } }
  .sm-sim { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
  .sm-sim3 { grid-template-columns:1fr 1fr 1fr; }
  @media (max-width:560px){ .sm-sim3{ grid-template-columns:1fr; } }
