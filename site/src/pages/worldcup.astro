---
import Base from '../layouts/Base.astro';
import Footer from '../components/Footer.astro';
import data from '../data/worldcup.json';
import wcl from '../data/wc_live.json';

const m = data.meta;
const h = data.headline;
const fc = data.forecast;
const live = fc.live2026;
const ho = fc.holdout;

// ── main chart geometry: skewness vs favourite probability ──
const W = 720, H = 430, P = { l: 56, r: 22, t: 22, b: 48 };
const xlo = 0.34, xhi = 0.92, ylo = -1.0, yhi = 0.65;
const X = (p) => P.l + ((p - xlo) / (xhi - xlo)) * (W - P.l - P.r);
const Y = (s) => P.t + (1 - (s - ylo) / (yhi - ylo)) * (H - P.t - P.b);
const curve = data.curve.map(d => `${X(d.p).toFixed(1)},${Y(d.skew).toFixed(1)}`).join(' ');
const xticks = [0.4, 0.5, 0.6, 0.7, 0.8, 0.9];
const yticks = [-1.0, -0.5, 0, 0.5];
const fmt = (x, d = 3) => (x >= 0 ? '+' : '') + x.toFixed(d);
const pct = (x) => (x * 100).toFixed(0) + '%';
---
<Base title="The World Cup skewness forecast — skew-dynamic"
      description="A live spin-off of the skew-dynamic study: the same structural law predicts the return-skewness of World Cup favourite bets, out-of-sample, with no odds — validated across 96 years of World Cups and tracking the 2026 tournament in real time."
      path="/worldcup">
  <header class="wc-top">
    <div class="container wc-top-inner">
      <a class="brand" href="/"><span class="brand-mark"></span>skew<span class="brand-dim">-dynamic</span></a>
      <div class="wc-top-links">
        <a href="/">← The study</a>
        <a href="https://github.com/cold-code-labs/skew-dynamic" target="_blank" rel="noopener">GitHub ↗</a>
      </div>
    </div>
  </header>

  <section class="wc-hero">
    <div class="container">
      <div class="eyebrow reveal">Annex · live during the 2026 tournament</div>
      <h1 class="reveal">The same law predicts the World Cup.</h1>
      <p class="lede reveal">The study showed a favourite's bet skewness is fixed by one number — its win
        probability <span class="mono">p</span> — through <span class="mono">(1−2p)/√(p(1−p))</span>. Here we
        take that law <em>out of its own population</em>: from club leagues to national teams, from market odds
        to <strong>no odds at all</strong>. We rebuild each side's strength from results only (a chronological
        Elo over {m.n_intl.toLocaleString()} internationals), turn it into a favourite probability, and predict
        the skewness of the 1X2 favourite bet across every World Cup from {m.edition_min} to {m.edition_max}.</p>
      <div class="wc-stats reveal">
        <div><span class="big">{fmt(h.corr_bucket, 3)}</span><label>predicted ↔ realised<br/>across p-buckets</label></div>
        <div><span class="big">{m.n_wc.toLocaleString()}</span><label>World Cup matches<br/>{m.edition_min}–{m.edition_max}</label></div>
        <div><span class="big">0</span><label>betting odds used<br/>(Elo only)</label></div>
      </div>
    </div>
  </section>

  <hr class="divider" />

  <!-- ── INTERACTIVE: the next match ── -->
  <section class="container" id="next-match">
    <div class="section-head reveal">
      <div class="eyebrow">● Live · the practical demonstration</div>
      <h2>The next match — predicted before it's played.</h2>
      <p class="lede">For every upcoming fixture the model names the favourite, its win probability, and the
        <strong>skewness of a unit bet on it</strong> — frozen into a
        <a href="https://github.com/cold-code-labs/skew-dynamic/blob/main/site/src/data/wc_predictions.json" target="_blank" rel="noopener">pre-registered ledger</a>
        and checked against reality when the result lands. Pick a fixture:</p>
    </div>

    {wcl.next ? <div class="nm reveal">
      <div class="nm-chips" id="nm-chips">
        {wcl.upcoming.map((f, i) => <button class="nm-chip" data-i={i}>
          <span class="nm-chip-d">{f.date.slice(5)}</span>
          {f.home_flag && <img class="nm-chip-flag" src={`https://flagcdn.com/w20/${f.home_flag}.png`} alt="" width="18" height="13" />}
          {f.home}<span class="nm-chip-x">×</span>{f.away}
          {f.away_flag && <img class="nm-chip-flag" src={`https://flagcdn.com/w20/${f.away_flag}.png`} alt="" width="18" height="13" />}
        </button>)}
      </div>

      <div class="nm-card">
        <div class="nm-fixture">
          <div class="nm-side" id="nm-side-h">
            <img class="nm-flag" id="nm-flag-h" alt="" width="68" height="46" />
            <div class="nm-team" id="nm-home"></div>
            <div class="nm-wprob" id="nm-wph"></div>
          </div>
          <div class="nm-center">
            <span class="nm-vs">vs</span>
            <span class="nm-date" id="nm-date"></span>
            <span class="nm-venue" id="nm-venue"></span>
          </div>
          <div class="nm-side" id="nm-side-a">
            <img class="nm-flag" id="nm-flag-a" alt="" width="68" height="46" />
            <div class="nm-team" id="nm-away"></div>
            <div class="nm-wprob" id="nm-wpa"></div>
          </div>
        </div>

        <div class="nm-wdl">
          <div class="nm-wdl-bar">
            <span class="seg seg-h" id="nm-seg-h"></span>
            <span class="seg seg-d" id="nm-seg-d"></span>
            <span class="seg seg-a" id="nm-seg-a"></span>
          </div>
          <div class="nm-wdl-key">
            <span><i class="dot dot-h"></i><b id="nm-kh"></b> <span id="nm-khn"></span></span>
            <span><i class="dot dot-d"></i><b id="nm-kd"></b> draw</span>
            <span><i class="dot dot-a"></i><b id="nm-ka"></b> <span id="nm-kan"></span></span>
          </div>
        </div>

        <div class="nm-forecast" id="nm-forecast">
          <div class="nm-fc-card" id="nm-fc-goals">
            <div class="nm-fc-label">Predicted scoreline</div>
            <div class="nm-fc-score"><span id="nm-sc-h">–</span><i>:</i><span id="nm-sc-a">–</span></div>
            <div class="nm-fc-xg">expected goals <b id="nm-xg-h"></b> – <b id="nm-xg-a"></b></div>
          </div>
          <div class="nm-fc-card">
            <div class="nm-fc-label">Knockout — chance to advance</div>
            <div class="nm-adv-bar"><span class="adv-h" id="nm-adv-h"></span><span class="adv-a" id="nm-adv-a"></span></div>
            <div class="nm-adv-key">
              <span><b id="nm-advh"></b> <span id="nm-advhn"></span></span>
              <span><span id="nm-advan"></span> <b id="nm-adva"></b></span>
            </div>
            <div class="nm-pens" id="nm-pens"></div>
          </div>
        </div>

        <div class="nm-bet">
          <div class="nm-bet-line">Bet on the favourite — <b id="nm-fav"></b></div>
          <div class="nm-verdict" id="nm-verdict"></div>
          <div class="nm-viz">
            <svg viewBox="0 0 340 200" id="nm-payoff" role="img" aria-label="Two-point payoff shape of the favourite bet">
              <line x1="40" y1="150" x2="320" y2="150" class="grid" stroke-opacity=".5" />
              <text class="tick" x="40" y="172" text-anchor="middle">−1</text>
              <text class="tick" x="320" y="172" text-anchor="end" id="nm-axwin">+0.8</text>
              <text class="tick" x="180" y="172" text-anchor="middle">0</text>
              <rect id="nm-bar-lose" x="64" width="48" rx="4" fill="var(--neg)" />
              <rect id="nm-bar-win"  x="248" width="48" rx="4" fill="var(--pos)" />
              <text id="nm-lbl-lose" class="nm-bl" x="88" text-anchor="middle"></text>
              <text id="nm-lbl-win"  class="nm-bl" x="272" text-anchor="middle"></text>
              <text class="nm-axl" x="88" y="192" text-anchor="middle">loses</text>
              <text class="nm-axl" x="272" y="192" text-anchor="middle">wins</text>
            </svg>
            <div class="nm-skewbox">
              <div class="nm-skewnum" id="nm-skew"></div>
              <label>predicted skewness</label>
              <p class="note" id="nm-betnote"></p>
            </div>
          </div>
        </div>
        <div class="nm-stamp">pre-registered as-of <span class="mono">{wcl.meta.data_date}</span> · model
          <span class="mono">elo-results-only</span> · awaiting result</div>
      </div>
    </div> : <p class="lede">No upcoming fixtures in the dataset right now — the bracket is complete.</p>}

    {wcl.recent_games && wcl.recent_games.length > 0 && <div class="nm-results reveal">
      <div class="nm-results-head">Recent results · 2026 group stage</div>
      <div class="nm-results-grid">
        {wcl.recent_games.map(g => <div class="rg">
          <div class="rg-team">
            {g.home_flag && <img src={`https://flagcdn.com/w40/${g.home_flag}.png`} alt="" width="26" height="17" />}
            <span class={g.fav_team===g.home ? 'rg-fav' : ''}>{g.home}</span>
          </div>
          <div class="rg-score">{g.fh}<span>–</span>{g.fa}</div>
          <div class="rg-team rg-away">
            <span class={g.fav_team===g.away ? 'rg-fav' : ''}>{g.away}</span>
            {g.away_flag && <img src={`https://flagcdn.com/w40/${g.away_flag}.png`} alt="" width="26" height="17" />}
          </div>
          <div class={`rg-mark ${g.fav_won ? 'ok' : 'no'}`} title={g.fav_won ? 'favourite won' : 'upset'}>{g.fav_won ? '✓' : '✗'}</div>
        </div>)}
      </div>
      <p class="note">✓ = the model favourite won. The skewness prediction lives upstream of the result — it's a
        property of the bet's shape, not a tip on who wins.</p>
    </div>}

    <div class="nm-score reveal">
      <div class="nm-score-card">
        <div class="nm-score-tag">2026 so far · model backtest</div>
        <div class="nm-score-rows">
          <div><span>matches played</span><b class="mono">{wcl.backtest2026.n}</b></div>
          <div><span>skew predicted</span><b class="mono">{fmt(wcl.backtest2026.skew_pred_pool)}</b></div>
          <div><span>skew realised</span><b class="mono">{fmt(wcl.backtest2026.skew_real_pool)}</b></div>
          <div><span>favourite hit rate</span><b class="mono">{(wcl.backtest2026.fav_hit_rate*100).toFixed(0)}%</b></div>
          <div><span>Brier score</span><b class="mono">{wcl.backtest2026.brier.toFixed(3)}</b></div>
        </div>
      </div>
      <div class="nm-score-card">
        <div class="nm-score-tag">Pre-registered ledger</div>
        <div class="nm-score-rows">
          <div><span>predictions pending</span><b class="mono">{wcl.ledger.n_pending}</b></div>
          <div><span>predictions resolved</span><b class="mono">{wcl.ledger.n_resolved}</b></div>
          {wcl.ledger.n_resolved >= 3 && <div><span>resolved hit rate</span><b class="mono">{(wcl.ledger.resolved_hit_rate*100).toFixed(0)}%</b></div>}
        </div>
        <p class="note">Frozen predictions; realised values fill in as the Round of 32 plays. The ledger is the
          tamper-evident record of predicted vs realised — append-only, committed to git.</p>
      </div>
    </div>
  </section>

  <hr class="divider" />

  <section class="container">
    <div class="section-head reveal">
      <div class="eyebrow">The validation</div>
      <h2>Predicted skewness lands on the realised — out of sample.</h2>
      <p class="lede">Each dot is a bucket of World Cup matches at a given favourite strength. The line is the
        structural law — <em>no fitting, no odds</em>. Realised skewness (filled) tracks the prediction (curve)
        from balanced ties on the left to lopsided mismatches on the right, crossing zero right at
        <span class="mono">p = ½</span>.</p>
    </div>

    <figure class="chart-figure reveal">
      <svg viewBox={`0 0 ${W} ${H}`} class="wc-svg" role="img" aria-label="World Cup skewness: predicted law versus realised, by favourite probability">
        {yticks.map(t => <g>
          <line class="grid" x1={P.l} y1={Y(t)} x2={W-P.r} y2={Y(t)} stroke-opacity={t===0?'.5':'.16'} stroke-dasharray={t===0?'':'3 3'} />
          <text class="tick" x={P.l-10} y={Y(t)+4} text-anchor="end">{t.toFixed(1)}</text>
        </g>)}
        {xticks.map(t => <g>
          <text class="tick" x={X(t)} y={H-P.b+18} text-anchor="middle">{t.toFixed(1)}</text>
        </g>)}
        <line class="grid" x1={X(0.5)} y1={P.t} x2={X(0.5)} y2={H-P.b} stroke-dasharray="3 3" stroke-opacity=".4" />
        <polyline points={curve} fill="none" stroke="var(--ink-faint)" stroke-width="2.5" />
        {data.buckets.map(d => <g>
          <line x1={X(d.p_fav)} y1={Y(d.skew_pred)} x2={X(d.p_fav)} y2={Y(d.skew_real)} stroke="var(--line)" stroke-width="1.5" />
          <circle cx={X(d.p_fav)} cy={Y(d.skew_pred)} r="4.5" fill="none" stroke="var(--ink-faint)" stroke-width="2"
                  data-tip={`predicted  p=${d.p_fav.toFixed(2)}  skew=${fmt(d.skew_pred,2)}`} />
          <circle cx={X(d.p_fav)} cy={Y(d.skew_real)} r="6" fill="var(--accent)"
                  data-tip={`realised  p=${d.p_fav.toFixed(2)}  skew=${fmt(d.skew_real,2)}  (n=${d.n})`} />
        </g>)}
        <text class="axis-label" x={W/2} y={H-8} text-anchor="middle">favourite win probability  p</text>
        <text class="axis-label" x="15" y={H/2} text-anchor="middle" transform={`rotate(-90 15 ${H/2})`}>return skewness</text>
      </svg>
      <figcaption class="chart-caption">
        <span class="key"><span class="sw line"></span>structural law (1−2p)/√(p(1−p))</span>
        <span class="key"><span class="sw ring"></span>predicted</span>
        <span class="key"><span class="sw" style="background:var(--accent)"></span>realised</span>
        — {m.n_wc.toLocaleString()} matches, {m.editions} World Cups. Pooled: predicted {fmt(h.skew_pred_pool)}, realised {fmt(h.skew_real_pool)}.
      </figcaption>
    </figure>

    <div class="wc-table-wrap reveal">
      <table class="wc-table">
        <thead><tr><th>favourite p</th><th>matches</th><th>win rate</th><th>skew predicted</th><th>skew realised</th></tr></thead>
        <tbody>
          {data.buckets.map(d => <tr>
            <td class="mono">{d.p_fav.toFixed(2)}</td>
            <td class="mono">{d.n}</td>
            <td class="mono">{pct(d.win_rate)}</td>
            <td class="mono">{fmt(d.skew_pred,2)}</td>
            <td class="mono" style={`color:${d.skew_real>=0?'var(--pos)':'var(--neg)'}`}>{fmt(d.skew_real,2)}</td>
          </tr>)}
        </tbody>
      </table>
      <p class="note">Win rate ≈ favourite probability in every row — the odds-free Elo is well-calibrated on
        real World Cup outcomes, which is what lets the structural skewness prediction hold.</p>
    </div>
  </section>

  <hr class="divider" />

  <section class="container">
    <div class="section-head reveal">
      <div class="eyebrow">The forecast</div>
      <h2>Calling the next round before it's played.</h2>
      <p class="lede">The honest test: train the Elo only on matches <em>before</em> a tournament's knockout
        stage, then predict the skewness of the bracket without seeing a single result.</p>
    </div>
    <div class="wc-cards">
      {ho && <div class="wc-card reveal">
        <div class="wc-card-tag">Hold-out · {ho.edition} knockout</div>
        <div class="wc-card-rows">
          <div><span>predicted</span><b class="mono">{fmt(ho.skew_pred,3)}</b></div>
          <div><span>realised</span><b class="mono">{fmt(ho.skew_real,3)}</b></div>
          <div><span>upsets</span><b class="mono">{pct(ho.upset_rate)}</b></div>
        </div>
        <p class="note">{ho.n} knockout matches, trained on data through the group stage only. Knockouts are
          small samples and high-variance — the prediction is the structural baseline the chaos deviates from.</p>
      </div>}
      <div class="wc-card wc-card-live reveal">
        <div class="wc-card-tag">{live ? '● Live · World Cup 2026' : 'World Cup 2026'}</div>
        {live ? <div class="wc-card-rows">
          <div><span>matches so far</span><b class="mono">{live.n_played}</b></div>
          <div><span>avg favourite p</span><b class="mono">{live.p_fav_mean.toFixed(3)}</b></div>
          <div><span>predicted skew</span><b class="mono">{fmt(live.skew_pred,3)}</b></div>
          <div><span>realised skew</span><b class="mono">{live.skew_real==null?'—':fmt(live.skew_real,3)}</b></div>
        </div> : <p class="note">Awaiting kickoff in the dataset.</p>}
        <p class="note">{live ? `Updates as the tournament unfolds — data through ${live.date_max}.` : ''}
          This page regenerates from the live results feed.</p>
      </div>
    </div>
  </section>

  <hr class="divider" />

  <section class="container wc-repro reveal">
    <div class="eyebrow">Reproduce</div>
    <p>Everything here is one command on the public dataset — no API keys, no scraping:</p>
    <pre class="code"><code>git clone https://github.com/cold-code-labs/skew-dynamic
cd skew-dynamic/study
python analysis/41_worldcup.py        # the full analysis
python analysis/export_worldcup_data.py   # regenerate this page's data</code></pre>
    <p class="note">Source: <a href="https://github.com/martj42/international_results" target="_blank" rel="noopener">martj42/international_results</a>
      ({m.n_intl.toLocaleString()} internationals, 1872–{m.date_max.slice(0,4)}) · dataset sha256 <span class="mono">{m.sha256}</span> ·
      the favourite-bet skewness law is derived in <a href="/">the main study</a>.</p>
  </section>

  <Footer />
</Base>

<script define:vars={{ FX: wcl.upcoming }}>
  const VERDICT = {
    neg_strong: 'Heavily left-skewed: frequent small wins, rare painful losses — the favourite-bet signature.',
    neg: 'Left-skewed: the favourite usually wins small, and occasionally loses big.',
    flat: 'Near-symmetric: a coin-flip tie, skewness sits right around zero at p = ½.',
    pos: 'Right-skewed: an even match where the bet behaves like a mild longshot.',
    pos_strong: 'Strongly right-skewed: the underdog-flavoured upside tail dominates.',
  };
  const $ = (id) => document.getElementById(id);
  const sgn = (x, d = 2) => (x >= 0 ? '+' : '') + x.toFixed(d);
  const pc = (x) => Math.round(x*100) + '%';
  const flagSrc = (iso) => iso ? `https://flagcdn.com/w80/${iso}.png` : '';

  function setFlag(img, iso, name) {
    if (iso) { img.src = flagSrc(iso); img.style.display = ''; img.alt = name; }
    else { img.style.display = 'none'; }
  }

  function render(i) {
    const f = FX[i]; if (!f) return;
    const favH = f.fav_pick === 'H', favA = f.fav_pick === 'A';
    $('nm-home').textContent = f.home;
    $('nm-away').textContent = f.away;
    $('nm-side-h').classList.toggle('fav', favH);
    $('nm-side-a').classList.toggle('fav', favA);
    setFlag($('nm-flag-h'), f.home_flag, f.home);
    setFlag($('nm-flag-a'), f.away_flag, f.away);
    $('nm-date').textContent = new Date(f.date + 'T12:00:00').toLocaleDateString('en-GB', { day:'numeric', month:'short', year:'numeric' });
    $('nm-venue').textContent = f.neutral ? 'neutral venue' : `${f.home} hosting`;

    // goals forecast (Poisson) + knockout / penalties
    const hasG = f.xg_home != null;
    $('nm-fc-goals').style.display = hasG ? '' : 'none';
    if (hasG) {
      $('nm-sc-h').textContent = f.score_home; $('nm-sc-a').textContent = f.score_away;
      $('nm-xg-h').textContent = f.xg_home.toFixed(2); $('nm-xg-a').textContent = f.xg_away.toFixed(2);
    }
    const ah = f.adv_home ?? f.p_fav, aa = f.adv_away ?? (1 - (f.adv_home ?? f.p_fav));
    $('nm-adv-h').style.width = (ah*100)+'%'; $('nm-adv-a').style.width = (aa*100)+'%';
    $('nm-advh').textContent = pc(ah); $('nm-advhn').textContent = f.home;
    $('nm-adva').textContent = pc(aa); $('nm-advan').textContent = f.away;
    const pen = f.pen_home ?? 0.5;
    $('nm-pens').innerHTML = `<span>🥅 if it goes to penalties:</span> <b>${f.home} ${pc(pen)}</b> · <b>${f.away} ${pc(1-pen)}</b> <em>— shootouts are near coin-flips</em>`;

    // 3-way W/D/L bar
    const ph = f.p_home ?? f.p_fav, pd = f.p_draw ?? 0, pa = f.p_away ?? 0;
    $('nm-wph').textContent = pc(ph);
    $('nm-wpa').textContent = pc(pa);
    $('nm-seg-h').style.width = (ph*100)+'%';
    $('nm-seg-d').style.width = (pd*100)+'%';
    $('nm-seg-a').style.width = (pa*100)+'%';
    $('nm-kh').textContent = pc(ph); $('nm-khn').textContent = f.home + ' win';
    $('nm-kd').textContent = pc(pd);
    $('nm-ka').textContent = pc(pa); $('nm-kan').textContent = f.away + ' win';

    // the bet
    $('nm-fav').textContent = `${f.fav_team} (${pc(f.p_fav)})`;
    const sk = $('nm-skew'); sk.textContent = sgn(f.skew_pred);
    sk.style.color = f.skew_pred >= 0.1 ? 'var(--pos)' : (f.skew_pred <= -0.1 ? 'var(--neg)' : 'var(--ink)');
    $('nm-verdict').textContent = VERDICT[f.verdict] || '';
    $('nm-betnote').textContent =
      `${f.fav_team} wins ${pc(f.p_fav)} of the time for a small ${sgn(f.win_payoff)}; the other `
      + `${pc(1-f.p_fav)} loses −1. The gap between those two odds is the skewness — no betting odds needed.`;

    // payoff bars
    const p = f.p_fav, q = 1 - p, base = 150, scale = 108;
    const win = $('nm-bar-win'), lose = $('nm-bar-lose');
    win.setAttribute('height', (p*scale).toFixed(1));  win.setAttribute('y', (base - p*scale).toFixed(1));
    lose.setAttribute('height', (q*scale).toFixed(1)); lose.setAttribute('y', (base - q*scale).toFixed(1));
    $('nm-lbl-win').setAttribute('y', (base - p*scale - 6).toFixed(1));
    $('nm-lbl-lose').setAttribute('y', (base - q*scale - 6).toFixed(1));
    $('nm-lbl-win').textContent = pc(p);
    $('nm-lbl-lose').textContent = pc(q);
    $('nm-axwin').textContent = sgn(f.win_payoff);
    document.querySelectorAll('.nm-chip').forEach((c, j) => c.classList.toggle('on', j === i));
  }
  document.querySelectorAll('.nm-chip').forEach((c) =>
