{
  "name": "template-web-coolify-light",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "predev": "bash scripts/ensure-deps.sh",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "pb:dev": "bash scripts/pb-dev.sh",
    "dev:local": "bash scripts/dev-local.sh",
    "preview": "bash scripts/dev-preview.sh",
    "db:migrate": "for f in db/migrations/*.sql; do echo \"applying $f\"; psql \"$DATABASE_URL\" -f \"$f\" || exit 1; done",
    "db:seed": "psql \"$DATABASE_URL\" -f db/seed.sql"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@base-ui/react": "^1.5.0",
    "@logto/next": "^4.2.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "pocketbase": "^0.27.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "shadcn": "^4.8.0",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^24",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "postcss": "^8.5",
    "tailwindcss": "^4.2.0",
    "typescript": "5.7.3"
  }
}
