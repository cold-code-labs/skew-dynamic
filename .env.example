# ─────────────────────────────────────────────────────────────────────────────
# template-web-coolify-light — configuration
#
# The "light" tier: the Next.js template app + a PocketBase backend bundled in
# ONE container. With the defaults below the app runs in "stub" mode (demo login
# + demo data, no backend). Set AUTH_MODE=pocketbase + DATA_MODE=pocketbase to
# use the bundled PocketBase — which is exactly how the 1-click deploy ships.
# ─────────────────────────────────────────────────────────────────────────────

# Public base URL of this deployment (auth redirects + deep-links).
APP_BASE_URL=http://localhost:3000

# App display name (rebrands the UI; safe to expose).
NEXT_PUBLIC_APP_NAME=Template

# Color identity. One of: neutral | indigo | emerald | violet | amber | rose.
# Overrides BRAND.theme in config/brand.ts. Repaints the whole app.
NEXT_PUBLIC_THEME=indigo

# Server log verbosity (see lib/log.ts). At boot the container logs a config
# summary showing which features are wired vs in demo mode — the fastest way to
# diagnose a fresh deploy. Caught failures are logged with their real detail
# (PocketBase status/url/field errors) while users still see friendly messages.
# One of: debug | info | warn | error | silent. Default: info.
LOG_LEVEL=info

# ── Feature selection ────────────────────────────────────────────────────────
# Comma-separated extra modules this instance ships with (see features.json for
# the catalog). Core modules (dashboard, notificacoes, busca, arquivos, conta,
# acessos) are ALWAYS on. Unset/empty = everything on (the showroom default).
# Example: only the Clientes + Financeiro extras →
#   APP_FEATURES=clientes,financeiro
# Core-only instance → APP_FEATURES=core
APP_FEATURES=

# ── Backend mode ─────────────────────────────────────────────────────────────
# stub       = demo login + in-code demo data (no backend)
# pocketbase = the bundled PocketBase (this tier's default for a real deploy)
# hauldr     = a Hauldr project: GoTrue auth + PostgREST data on real Postgres,
#              with per-user RLS (the "BaaS" tier — see the Hauldr block below).
# logto/postgrest stubs remain for seam parity; the à-la-carte template is archived.
AUTH_MODE=stub
DATA_MODE=stub

# ── Dev target: local PocketBase vs. live remote backend ─────────────────────
# A clean clone runs in demo mode with NO .env at all (APP_ENV=dev, AUTH_MODE=
# stub). APP_ENV only decides which PocketBase a LOCAL checkout talks to when
# DATA_MODE/AUTH_MODE=pocketbase (production is unaffected — the container always
# uses its bundled localhost PocketBase):
#   DEV (default) → a PocketBase you run locally: `pnpm pb:dev` (→ :8090).
#                   Edit schema in /_/ and the changes become migration files in
#                   pocketbase/pb_migrations — commit + push and the live backend
#                   applies them on the next deploy.
#   PRD           → this instance's LIVE remote backend (reads/writes hit prod).
#                   Needs the Cloudflare Access service token below.
APP_ENV=DEV

# Local PocketBase URL used when APP_ENV=DEV (default is fine for `pnpm pb:dev`).
POCKETBASE_URL_LOCAL=http://127.0.0.1:8090
# Live remote backend used when APP_ENV=PRD (the instance's data-<sub> host).
# The .env you download from Heimdall (Fleet) already fills this for you.
POCKETBASE_URL_REMOTE=

# Cloudflare Access service token — only used when APP_ENV=PRD (the remote sits
# behind Access, locked to service-token-only). Filled by the Heimdall download.
PB_CF_ACCESS_CLIENT_ID=
PB_CF_ACCESS_CLIENT_SECRET=

# Explicit override (advanced): if set to a LOOPBACK url it always wins (this is
# how the production container pins itself to its bundled PocketBase). Leave unset
# locally and let APP_ENV choose.
# POCKETBASE_URL=http://127.0.0.1:8090

# Cloudflare Access service token — ONLY needed when POCKETBASE_URL points at a
# PocketBase behind Cloudflare Access (e.g. a local checkout talking to the live
# data-<sub>.coldcodelabs.com URL). Set both and every PB request is sent with
# the CF-Access-Client-Id/Secret headers. Leave empty for the bundled localhost
# default. (Heimdall's "Clonar" fills these in automatically in the .env it ships.)
PB_CF_ACCESS_CLIENT_ID=
PB_CF_ACCESS_CLIENT_SECRET=

# ── PocketBase superuser (admin /_/) bootstrap ───────────────────────────────
# Set both to auto-create the admin on first boot (skips the /_/ setup screen).
# These are read by the container entrypoint, not the Next app.
PB_SUPERUSER_EMAIL=
PB_SUPERUSER_PASSWORD=

# ── Hauldr tier (AUTH_MODE=hauldr + DATA_MODE=postgrest) ─────────────────────
# A Hauldr project gives the app GoTrue auth + a PostgREST data-API over real
# Postgres, with per-user RLS (rows keyed to the JWT `sub`). Same APP_ENV rule as
# PocketBase: PRODUCTION is native (the internal Coolify-network URLs below —
# DB/services never public), and a LOCAL checkout opts into the project's PUBLIC
# dev endpoints with APP_ENV=DEV + the *_REMOTE vars.
#
#   AUTH_MODE=hauldr
#   DATA_MODE=postgrest
#
# Production (internal, set on the Coolify app — never public):
#   HAULDR_GOTRUE_URL=http://<project-gotrue>:9999
#   DATA_API_URL=http://<project-rest>:3000
# Local dev "from outside" (APP_ENV=DEV picks these public URLs):
#   HAULDR_GOTRUE_URL_REMOTE=https://auth-<project>.coldcodelabs.com
#   DATA_API_URL_REMOTE=https://rest-<project>.coldcodelabs.com
#
# The project's GoTrue HS256 secret — verifies access tokens locally AND is the
# secret PostgREST is configured with (PGRST_JWT_SECRET). Required in both envs.
HAULDR_JWT_SECRET=
# App capability role for a Hauldr user with no explicit role claim (default owner).
# HAULDR_DEFAULT_ROLE=owner
# Leave DATA_API_TOKEN UNSET in this tier so the signed-in user's token is
# forwarded (per-user RLS) instead of a god-mode service role.
HAULDR_GOTRUE_URL=
HAULDR_GOTRUE_URL_REMOTE=
DATA_API_URL=
DATA_API_URL_REMOTE=

# A demo login user is seeded by the PocketBase migration out of the box:
#   demo@coldcodelabs.com / snowdemo123   (change it in the admin UI)

# One-click "Entrar como demo" button (DEV/DEMO ONLY — anyone can click in).
# Leave empty/false in production; the real email/password form is always shown.
DEMO_LOGIN=
# Which user the demo button logs in as (defaults match the seeded migration).
DEMO_LOGIN_EMAIL=demo@coldcodelabs.com
DEMO_LOGIN_PASSWORD=snowdemo123

# ── Logto (only if AUTH_MODE=logto) ──────────────────────────────────────────
LOGTO_ENDPOINT=https://auth.coldcodelabs.com
LOGTO_APP_ID=
LOGTO_APP_SECRET=
LOGTO_BASE_URL=http://localhost:3000
LOGTO_COOKIE_SECRET=

# ── PostgREST (only if DATA_MODE=postgrest) ──────────────────────────────────
DATA_API_URL=
DATA_API_TOKEN=

# ── Functions (optional) ─────────────────────────────────────────────────────
FUNCTIONS_URL=

# ── Reuniões Gravadas / transcrição (optional) ───────────────────────────────
# The "Reuniões Gravadas" module records audio in the browser and stores it in
# PocketBase with NO key. Transcription is à-la-carte, two providers:
#   openai   = Whisper, plain transcript (no speakers). Default.
#   deepgram = Deepgram with diarization → "quem falou o quê" (Locutor 1/2/3…).
TRANSCRIBE_PROVIDER=openai
# OpenAI (when TRANSCRIBE_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=whisper-1
OPENAI_BASE_URL=https://api.openai.com/v1
# Deepgram (when TRANSCRIBE_PROVIDER=deepgram) — diarization on by default
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2
# Show the experimental "transcrição ao vivo" toggle (streaming not wired yet).
MEETINGS_REALTIME=

# ── Chamados / Service desk (optional) ───────────────────────────────────────
# The "Chamados" module always posts an in-app notification on every ticket
# event (new chamado, comment, status change, assignment). Optionally also fan
# events out to an outbound webhook (Resend/n8n/Make/Slack/Teams) as JSON, e.g.
# to send email — leave empty for in-app notifications only.
CHAMADOS_NOTIFY_WEBHOOK=

# ── Chat (optional) ──────────────────────────────────────────────────────────
# The "Chat" module (role-gated channels + 1:1 DMs) is realtime out of the box —
# messages stream from the bundled PocketBase via a server-side SSE relay, so it
# needs NO env to work. Optionally fan new-DM events out to a webhook (email/
# Slack/Teams) as JSON — leave empty for in-app notifications only.
CHAT_NOTIFY_WEBHOOK=

# ── Assinatura / Stripe (optional) ───────────────────────────────────────────
# The "Assinatura" module sends the client into Stripe's hosted billing portal
# (update card, invoices, cancel). It renders NO billing data itself, so with
# nothing set below it just shows a "modo demonstração" notice. Wire it one of
# two ways:
#   • Simplest — paste the no-code customer-portal LOGIN link (the client signs
#     in to Stripe by email):
STRIPE_PORTAL_URL=
#   • Seamless — CCL secret key + this client's customer id; the button then
#     mints a one-time session straight to their portal (no email step):
STRIPE_SECRET_KEY=
STRIPE_CUSTOMER_ID=
# Stripe API base URL (point at a gateway/proxy without touching code).
STRIPE_API_BASE=https://api.stripe.com/v1

# ── Tenancy ──────────────────────────────────────────────────────────────────
# Multi-tenant mode is OFF by default: the app is single-tenant and the org
# switcher is hidden. Set MULTI_TENANT=true to scope data by organization.
MULTI_TENANT=
# Fallback tenant id (single-tenant deploys / unlinked users).
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000000
